<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Tauri merges this file during macOS packaging. The microphone usage string is
     required for WKWebView getUserMedia (voice input/STT); without it, the OS
     rejects access and kills the process. -->
<plist version="1.0">
<dict>
    <key>NSMicrophoneUsageDescription</key>
    <string>Voice input: record your speech to transcribe it into the chat box. Audio is sent only to the speech-to-text provider you configured.</string>
</dict>
</plist>
